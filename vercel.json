{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/guests",
      "destination": "/backend/index.js"
    },
    {
      "source": "/api/tables",
      "destination": "/backend/index.js"
    },
    {
      "source": "/api/health",
      "destination": "/backend/index.js"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}